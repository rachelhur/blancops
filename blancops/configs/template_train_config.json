{
    "cfg": "config.json",
    "save_to_model_dir": true,
    "model_name": "bc-azel-filter-nside16",
    "fits_path": "../data/decam-exposures-20251211.fits",
    "metadata": {
        "parent_results_dir": "experiments/nside16",
        "exp_name": "example",
        "seed": 10
    },
    "model": {
        "algorithm": "BC",
        "loss_function": "cross_entropy",
        "contextual_gating": false,
        "activation": "relu",
        "action_architecture": "simultaneous",
        "loss_strategy": "pure_joint"
    },
    "data": {
        "nside": 16,
        "action_space": "azel_filter",
        "specific_years": [
            2017,
            2018
        ],
        "specific_months": null,
        "specific_days": null,
        "specific_filters": null,
        "do_cyclical_norm": true,
        "do_max_norm": true,
        "do_inverse_norm": true,
        "bin_features": [
            "pointing_distance",
            "moon_distance",
            "ha",
            "az",
            "el",
            "ra",
            "dec",
            "airmass",
            "survey_num_unvisited_fields_r",
            "survey_num_unvisited_fields_g",
            "survey_num_unvisited_fields_i",
            "survey_num_unvisited_fields_z",
            "survey_num_unvisited_fields_Y",
            "survey_num_incomplete_fields_r",
            "survey_num_incomplete_fields_g",
            "survey_num_incomplete_fields_i",
            "survey_num_incomplete_fields_z",
            "survey_num_incomplete_fields_Y",
            "survey_min_tiling_r",
            "survey_min_tiling_g",
            "survey_min_tiling_i",
            "survey_min_tiling_z",
            "survey_min_tiling_Y"

        ],
        "do_ang_distance_norm": true,
        "global_features": [
            "ra",
            "dec",
            "az",
            "el",
            "airmass",
            "ha",
            "sun_ra",
            "sun_dec",
            "sun_az",
            "sun_el",
            "moon_ra",
            "moon_dec",
            "moon_az",
            "moon_el",
            "filter_wave",
            "lst",
            "t_night",
            "sky_brightness_g",
            "sky_brightness_r",
            "sky_brightness_i",
            "sky_brightness_z",
            "sky_brightness_Y"
        
        ],
        "reward_choice": "expert_actions",
    },
    "train": {
        "max_epochs": 200,
        "batch_size": 1024,
        "num_workers": 8,
        "use_train_as_val": false,
        "lr": 0.001,
        "lr_scheduler": "cosine_annealing",
        "lr_scheduler_num_epochs": 150,
        "lr_scheduler_epoch_start": 10,
        "eta_min": 1e-4,
        "hidden_dim": 64,
        "patience": 40
}
